# Smart Resource Allocation — Environment Variables
# Copy this as .env and fill in values

# App
APP_NAME="Smart Resource Allocation"
APP_ENV=production
APP_DEBUG=false

# Database (PostgreSQL — Aiven, Neon, Render, or Supabase)
DATABASE_URL=postgresql://user:password@host:port/dbname?ssl=require

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Deployment
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
PORT=8000
