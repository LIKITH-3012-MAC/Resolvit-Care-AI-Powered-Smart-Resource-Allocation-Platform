{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://resolvit-care-ai-powered-smart-resource.onrender.com/api/$1" },
    { "source": "/auth/(.*)", "destination": "https://resolvit-care-ai-powered-smart-resource.onrender.com/auth/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
