{
  "outputDirectory": "frontend_old",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://resolvit-care-ai-powered-smart-resource.onrender.com/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://resolvit-care-ai-powered-smart-resource.onrender.com/auth/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
